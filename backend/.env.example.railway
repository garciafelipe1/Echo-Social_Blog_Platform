# Copia y usa como referencia para variables en Railway (backend)
# NO subas valores reales. Configúralas en el dashboard de Railway.

SECRET_KEY=genera-una-clave-segura-de-50-caracteres
DEBUG=False
ALLOWED_HOSTS=*
SITE_NAME=EF
FRONTEND_URL=https://tu-frontend.up.railway.app
CORS_ORIGIN_WHITELIST=https://tu-frontend.up.railway.app
CSRF_TRUSTED_ORIGINS=https://tu-frontend.up.railway.app

# Railway añade DATABASE_URL automáticamente si conectas PostgreSQL
# DATABASE_URL=postgresql://...

USE_REDIS=false
# Si usas Redis en Railway, referencia REDIS_URL y pon USE_REDIS=true

RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=EF <onboarding@resend.dev>
