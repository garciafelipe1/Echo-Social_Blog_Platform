# Copia a .env en la raíz:  copy .env.example .env
# Luego:  npm run docker:up   (desde la raíz del proyecto)

# ----- Backend (Django) -----
SECRET_KEY=tu-secret-key-muy-segura-cambiar-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ORIGIN_WHITELIST=http://localhost:3006,http://127.0.0.1:3006
CSRF_TRUSTED_ORIGINS=http://localhost:3006,http://127.0.0.1:3006

# Base de datos (Docker: servicio postgres)
DATABASE_NAME=django_db
DATABASE_USER=django
DATABASE_PASSWORD=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432

# Redis (Docker: servicio redis)
USE_REDIS=true
REDIS_HOST=redis
REDIS_URL=redis://redis:6379/0

# Opcional: orígenes para Channels (WebSockets)
# CHANNELS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3006

# ----- Email (desarrollo) -----
# Por defecto: emails en backend/emails/ (archivos .log). NO se imprime en terminal.
# En login OTP: si DEBUG=True, el código aparece en la propia pantalla de login.
#
# Con Docker + Mailpit: ver todos los emails en http://localhost:8025
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=mailpit
# EMAIL_PORT=1025

# ----- Frontend (para enlaces en emails: activación, reset password) -----
# URL del frontend. Los enlaces del correo apuntan aquí.
# Local: http://localhost:3000  |  Docker: http://localhost:3006
FRONTEND_URL=http://localhost:3000

# Con Docker, API_URL y NEXT_PUBLIC_API_URL se sobreescriben en docker-compose.
