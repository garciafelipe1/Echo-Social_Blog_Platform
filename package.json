{
  "name": "fullstack-django-nextjs",
  "private": true,
  "scripts": {
    "dev": "concurrently -n back,front -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "node scripts/dev-backend.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:front": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "start": "npm run start --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
